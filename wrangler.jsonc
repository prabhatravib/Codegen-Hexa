{
  "name": "voice-codegen-hexa",
  "main": "src/worker-voice/index.ts",
  "compatibility_date": "2024-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "VOICE_SESSION",
        "class_name": "VoiceSession"
      }
    ]
  },
  "env": {
    "OPENAI_REALTIME_MODEL": ""
  },
  "vars": {
    "PYTHON_API_URL": ""
  }
}
